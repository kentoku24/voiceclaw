# voiceclaw configuration
# All settings are optional — OpenClaw gateway token is auto-detected from ~/.openclaw/openclaw.json

# Server
# HOST=127.0.0.1
# PORT=8788

# OpenClaw Gateway (auto-detected if not set)
# OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
# OPENCLAW_GATEWAY_TOKEN=

# LLM model (default: openclaw)
# OPENCLAW_MODEL=openclaw

# Wake words (comma-separated, longest first recommended)
# WAKE_WORDS=アリスちゃん,ありすちゃん,アリスチャン,アリス,ありす

# Speech recognition language
# STT_LANG=ja-JP

# VOICEVOX TTS
# VOICEVOX_URL=http://127.0.0.1:50021
# VOICEVOX_SPEAKER=1
