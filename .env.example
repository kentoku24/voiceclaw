# voiceclaw local node relay
# If you open the page on the SAME machine, HOST=127.0.0.1 is fine.
# If you open the page from another device (phone/tablet), set HOST=0.0.0.0 and use http://<PCのLAN IP>:<PORT>/
HOST=127.0.0.1
PORT=8788
DISCORD_CHANNEL_ID=1477615112008237210
# Recommended: use a webhook for sending so Chappy reacts (bots often ignore bot-authored messages)
DISCORD_WEBHOOK_URL=__PUT_DISCORD_WEBHOOK_URL_HERE__
# If Chappy requires mention activation, set this.
CHAPPY_MENTION=<@1467185317433049244>
# Required for reading channel messages (polling)
DISCORD_BOT_TOKEN=__PUT_YOUR_DISCORD_BOT_TOKEN_HERE__
